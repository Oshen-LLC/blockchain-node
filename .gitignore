# Fabric generated artifacts
*.tar.gz
channel-artifacts/
crypto-config/
organizations/  # Auto-generated, contains private keys

# Logs
*.log
logs/
node_modules/
dist/
tmp/
fabric-samples/

# Docker volumes and temporary state
docker-compose.override.yml
docker-compose.yaml  # Auto-generated by scripts/generate-orgs.sh
fabric-ca/
data/
.release/
peer0/
orderer/

# Environment files
.env
.env.local
.env.*.local
!.env.example                          # Allow example env files

# Temporary scripts and build outputs
*.sh
!install-fabric.sh
!scripts/*.sh
!scripts/deploy-*.sh                    # Allow deployment automation scripts
!scripts/fabric-*.sh                    # Allow Fabric-specific scripts
bin/
builders/

# IDE and OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Test artifacts
test-*.json
test-*.block
*.tx
*.block

# CouchDB data (if using local state DB)
couchdb-data/

# Orderer and peer runtime files
system-genesis-block/
filestore/

# MSP and TLS temporary files
*_sk
*_cert
*.pem
*.crt
*.key

# Fabric CA database
fabric-ca-server.db
fabric-ca-server.db-*

# Network setup scripts outputs
*.log
*.pid
*.sock

# Kubernetes manifests (if using K8s deployment)
*.yaml
!config/*.yaml
!network-config/*.yaml
!network-config/organizations.yaml      # Master config file
!infra/*.yaml                           # Allow infrastructure configs

# NOTE: This .gitignore is for the BLOCKCHAIN repository only
# Chaincode and Gateway API have their own repositories:
# - Chaincode: github.com/somalia-cert/chaincode
# - Gateway API: github.com/somalia-cert/gateway-api

# External repository references (should be in separate repos)
../chaincode/                            # Chaincode has its own repo
../gateway-api/                          # Gateway API has its own repo

# Cross-repo automation files (allow for CI/CD integration)
!scripts/integration-*.sh                # Allow integration scripts
!scripts/ci-*.sh                         # Allow CI/CD scripts
!scripts/deploy-*.sh                    # Allow deployment scripts
!deploy/                                # Allow deployment configs
!integration/                           # Allow integration test configs
